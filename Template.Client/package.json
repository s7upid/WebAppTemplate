{
  "name": "template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "solstice-ui": "https://github.com/s7upid/solstice-ui/releases/download/v1.0.0/solstice-ui-1.0.0.tgz",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^7.0.2",
    "@eslint/js": "^9.39.3",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "cypress": "^15.11.0",
    "cypress-split": "^1.24.28",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^7.2.1"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "npx tsc && npx vite build",
    "build:coverage": "npx tsc && npx vite build --mode coverage",
    "preview": "vite preview",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:ci": "jest --config jest.config.ts --ci --coverage --watchAll=false",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:parallel": "concurrently \"cypress run --env split=4,splitIndex=0\" \"cypress run --env split=4,splitIndex=1\" \"cypress run --env split=4,splitIndex=2\" \"cypress run --env split=4,splitIndex=3\"",
    "cypress:run:parallel:coverage": "concurrently \"cypress run --env split=4,splitIndex=0,ENABLE_COVERAGE=true\" \"cypress run --env split=4,splitIndex=1,ENABLE_COVERAGE=true\" \"cypress run --env split=4,splitIndex=2,ENABLE_COVERAGE=true\" \"cypress run --env split=4,splitIndex=3,ENABLE_COVERAGE=true\"",
    "cypress:merge-coverage": "node scripts/merge-cypress-coverage.mjs",
    "cypress:coverage": "c8 report --reporter=json --reporter=html --reporter=text -o coverage/cypress --src src",
    "clean": "rimraf coverage .nyc_output .c8_output build dist coverage-report.json",
    "clean:all": "rimraf coverage .nyc_output .c8_output build dist coverage-report.json node_modules"
  }
}
