{
  "name": "template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.0.1",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-devtools": "^5.91.2",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.48.2",
    "react-redux": "^9.0.4",
    "react-router-dom": "^7.9.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^7.0.2",
    "@eslint/js": "^9.28.0",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "c8": "^10.1.3",
    "cypress": "^15.3.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.0.0",
    "lucide-react": "^0.562.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^7.1.6",
    "vite-plugin-istanbul": "^7.2.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "npx tsc && npx vite build",
    "build:coverage": "npx tsc && npx vite build --mode coverage",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "chcp 65001 >nul 2>&1 & npx jest --config jest.config.ts",
    "test:watch": "chcp 65001 >nul 2>&1 & npx jest --config jest.config.ts --watch",
    "test:coverage": "chcp 65001 >nul 2>&1 & npx jest --config jest.config.ts --coverage",
    "test:ci": "chcp 65001 >nul 2>&1 & npx jest --config jest.config.ts --ci --coverage --watchAll=false",
    "test:win": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1",
    "test:win:watch": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 watch",
    "test:win:coverage": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1 coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:coverage": "c8 report --reporter=json --reporter=html --reporter=text -o coverage/cypress --src src",
    "clean": "rimraf coverage .nyc_output .c8_output build dist coverage-report.json",
    "clean:all": "rimraf coverage .nyc_output .c8_output build dist coverage-report.json node_modules"
  }
}
